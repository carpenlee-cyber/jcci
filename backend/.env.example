# ==========================================
# JCCI 生产部署环境变量模板
# 复制为 backend/.env 并修改
# ==========================================

# 调试模式（生产环境必须 False）
DEBUG=False

# 服务器绑定地址和端口
HOST=0.0.0.0
PORT=8000

# CORS 允许的前端域名（逗号分隔）
# 示例: https://jcci.example.com,https://admin.example.com
ALLOWED_ORIGINS=*

# LLM API 配置（必填，否则 AI 分析不可用）
LLM_API_URL=https://your-llm-api-endpoint/v1
LLM_API_KEY=sk-your-api-key-here
LLM_MODEL=your-model-name

# 数据库路径（默认即可）
DB_PATH=./data/jcci.db
